# Alpha Vantage - Free tier: 25 calls/day
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# FRED (Federal Reserve Economic Data) - Free
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI - Free tier: 100 requests/day (developer plan)
# Get key at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Anthropic Claude API
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reddit API - Free
# Create app at: https://www.reddit.com/prefs/apps
# Choose "script" type application
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=IndexFundForecaster/1.0 by YourUsername

# Redis (set automatically by Docker Compose — only override if running locally)
REDIS_URL=redis://redis:6379
